{
  "version": 2,
  "env": {
    "BETTER_AUTH_URL": "https://a09server.vercel.app",
    "PUBLIC_SERVER_URL": "https://a09server.vercel.app",
    "CORS_ORIGINS": "https://a09client.vercel.app,http://localhost:5173",
    "CLIENT_ORIGINS": "https://a09client.vercel.app,http://localhost:5173"
  },
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}